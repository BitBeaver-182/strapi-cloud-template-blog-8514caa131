{
  "kind": "collectionType",
  "collectionName": "quotes",
  "info": {
    "singularName": "quote",
    "pluralName": "quotes",
    "displayName": "Quote",
    "description": "Supplier quotation (commercial anchor). One supplier per quote."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "supplier": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::supplier.supplier",
      "inversedBy": "quotes"
    },
    "contract_no": {
      "type": "string"
    },
    "pi_no": {
      "type": "string"
    },
    "quotation_date": {
      "type": "date",
      "required": true
    },
    "expiration_date": {
      "type": "date",
      "required": true
    },
    "origin_country": {
      "type": "customField",
      "customField": "plugin::country-select.country"
    },
    "destination_country": {
      "type": "customField",
      "customField": "plugin::country-select.country"
    },
    "incoterm": {
      "type": "enumeration",
      "enum": [
        "FOB",
        "EXW",
        "CIF",
        "OTHER"
      ]
    },
    "amount": {
      "type": "decimal",
      "required": true
    },
    "notes": {
      "type": "text"
    },
    "quote_status": {
      "type": "enumeration",
      "default": "pending",
      "enum": [
        "pending",
        "accepted",
        "rejected"
      ]
    },
    "total": {
      "type": "component",
      "component": "shared.money",
      "repeatable": false
    },
    "total_display": {
      "type": "string"
    },
    "attachments": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "files",
        "images"
      ]
    },
    "pdf": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "files"
      ]
    },
    "orders": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order.order",
      "mappedBy": "quote"
    }
  }
}
