{
  "kind": "collectionType",
  "collectionName": "quotes",
  "info": {
    "singularName": "quote",
    "pluralName": "quotes",
    "displayName": "Quote",
    "description": "Supplier quotation (commercial anchor). One supplier per quote."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "supplier": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::supplier.supplier",
      "inversedBy": "quotes"
    },
    "contract_no": {
      "type": "string"
    },
    "pi_no": {
      "type": "string"
    },
    "quotation_date": {
      "type": "date",
      "required": true
    },
    "expiration_date": {
      "type": "date"
    },
    "origin_country": {
      "type": "customField",
      "customField": "plugin::country-select.country",
      "required": true
    },
    "destination_country": {
      "type": "customField",
      "customField": "plugin::country-select.country",
      "required": true
    },
    "incoterm": {
      "type": "enumeration",
      "enum": [
        "FOB",
        "EXW",
        "CIF",
        "OTHER"
      ]
    },
    "total": {
      "type": "component",
      "repeatable": false,
      "component": "shared.money"
    },
    "total_display": {
      "type": "string",
      "description": "Auto-filled from Total for list view (symbol + amount using currency decimals)."
    },
    "attachments": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "files",
        "images"
      ]
    },
    "orders": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order.order",
      "mappedBy": "quote"
    }
  }
}
