{
  "kind": "collectionType",
  "collectionName": "quotes",
  "info": {
    "singularName": "quote",
    "pluralName": "quotes",
    "displayName": "Quote",
    "description": "Supplier quotation (commercial anchor). One supplier per quote."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "supplier": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::supplier.supplier",
      "inversedBy": "quotes"
    },
    "quotation_date": {
      "type": "date",
      "required": true
    },
    "expiration_date": {
      "type": "date",
      "required": true
    },
    "notes": {
      "type": "text"
    },
    "quote_status": {
      "type": "enumeration",
      "default": "pending",
      "enum": [
        "pending",
        "accepted",
        "rejected"
      ]
    },
    "total": {
      "type": "component",
      "component": "shared.money",
      "repeatable": false
    },
    "pdf": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "files"
      ]
    },
    "orders": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order.order",
      "mappedBy": "quote"
    },
    "supplierOrders": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::supplier-order.supplier-order",
      "mappedBy": "quote"
    }
  }
}
