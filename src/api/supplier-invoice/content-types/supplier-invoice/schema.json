{
  "kind": "collectionType",
  "collectionName": "supplier_invoices",
  "info": {
    "singularName": "supplier-invoice",
    "pluralName": "supplier-invoices",
    "displayName": "Supplier Invoice",
    "description": "Invoice attached to a supplier order."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "supplierOrder": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::supplier-order.supplier-order",
      "inversedBy": "invoices"
    },
    "invoiceNumber": {
      "type": "string",
      "unique": true
    },
    "vendorName": {
      "type": "string",
      "required": true
    },
    "total": {
      "type": "component",
      "component": "shared.money",
      "repeatable": false
    },
    "amountPaid": {
      "type": "component",
      "component": "shared.money",
      "repeatable": false
    },
    "amountRemaining": {
      "type": "component",
      "component": "shared.money",
      "repeatable": false
    },
    "invoiceStatus": {
      "type": "enumeration",
      "required": false,
      "default": "pending",
      "enum": [
        "pending",
        "paid",
        "overdue"
      ]
    },
    "expirationDate": {
      "type": "datetime",
      "required": true
    },
    "attachment": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "files"
      ]
    },
    "payments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::supplier-invoice-payment.supplier-invoice-payment",
      "mappedBy": "invoice"
    }
  }
}